# Generated PDFs can always be rebuilt locally.
*.pdf
output/pdf/**/*.pdf

# Keep output folders available without committing generated files.
output/pdf/*
output/exports/*
output/audio/*
!output/pdf/.gitkeep
!output/exports/.gitkeep
!output/audio/.gitkeep

# Course-specific generated outputs.
courses/*/output/pdf/*
courses/*/output/exports/*
courses/*/output/audio/*
!courses/*/output/pdf/.gitkeep
!courses/*/output/exports/.gitkeep
!courses/*/output/audio/.gitkeep

# Local environment and caches.
.venv/
.cache/
__pycache__/
*.pyc
