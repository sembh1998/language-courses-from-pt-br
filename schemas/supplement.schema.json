{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fonte estruturada de suplemento de tópico",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "topic",
    "level",
    "source_topic_order",
    "mode"
  ],
  "anyOf": [
    { "required": ["exercises"] },
    { "required": ["test"] },
    { "required": ["stories"] }
  ],
  "properties": {
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "level": {
      "type": "string",
      "pattern": "^(A1|A2|B1|B2|C1|C2)$"
    },
    "source_topic_order": {
      "type": "integer",
      "minimum": 1
    },
    "mode": {
      "enum": [
        "extra_story",
        "extra_exercises",
        "extra_test",
        "mastery"
      ]
    },
    "description": {
      "type": "string"
    },
    "exercises": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/group"
      }
    },
    "test": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/item"
      }
    },
    "stories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/story"
      }
    }
  },
  "$defs": {
    "answer_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question",
        "answer"
      ],
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1
        },
        "answer": {
          "type": [
            "string",
            "number"
          ]
        },
        "explanation": {
          "type": "string"
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "question",
        "answer",
        "explanation"
      ],
      "properties": {
        "type": {
          "enum": [
            "multiple_choice",
            "fill_blank",
            "translation",
            "matching",
            "short_answer",
            "ordering",
            "transformation",
            "correction",
            "classification",
            "production",
            "contrast",
            "identification",
            "dictation"
          ]
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "answer": {
          "type": [
            "string",
            "number"
          ]
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "distractors": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "points": {
          "type": "number",
          "minimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "multiple_choice"
              }
            }
          },
          "then": {
            "required": [
              "distractors"
            ]
          }
        }
      ]
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "instruction",
        "items"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "instruction": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/item"
          }
        }
      }
    },
    "story": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "sections",
        "vocabulary_notes",
        "questions"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "sentences"
            ],
            "properties": {
              "heading": {
                "type": "string"
              },
              "sentences": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "target",
                    "translation"
                  ],
                  "properties": {
                    "target": {
                      "type": "string",
                      "minLength": 1
                    },
                    "translation": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          }
        },
        "vocabulary_notes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "target",
              "note"
            ],
            "properties": {
              "target": {
                "type": "string",
                "minLength": 1
              },
              "note": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/answer_item"
          }
        },
        "practice": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/answer_item"
          }
        }
      }
    }
  }
}
