{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fonte estruturada de um tópico",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "topic",
    "level",
    "lesson",
    "vocabulary",
    "exercises",
    "test",
    "story"
  ],
  "properties": {
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "level": {
      "type": "string",
      "pattern": "^(A1|A2|B1|B2|C1|C2)$"
    },
    "lesson": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objective",
        "explanation",
        "examples",
        "common_mistakes",
        "summary"
      ],
      "properties": {
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "examples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "target",
              "translation"
            ],
            "properties": {
              "target": {
                "type": "string",
                "minLength": 1
              },
              "translation": {
                "type": "string",
                "minLength": 1
              },
              "note": {
                "type": "string"
              }
            }
          }
        },
        "common_mistakes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "guided_practice": {
          "type": "string"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "vocabulary": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target",
          "translation",
          "example",
          "example_translation"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "translation": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string"
          },
          "gender": {
            "type": [
              "string",
              "null"
            ]
          },
          "plural": {
            "type": [
              "string",
              "null"
            ]
          },
          "example": {
            "type": "string",
            "minLength": 1
          },
          "example_translation": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string"
          },
          "flashcard": {
            "type": "boolean",
            "default": true
          },
          "flashcard_front": {
            "type": "string"
          },
          "flashcard_back": {
            "type": "string"
          }
        }
      }
    },
    "flashcards": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "front",
          "back",
          "example",
          "example_translation"
        ],
        "properties": {
          "front": {
            "type": "string",
            "minLength": 1
          },
          "back": {
            "type": "string",
            "minLength": 1
          },
          "example": {
            "type": "string",
            "minLength": 1
          },
          "example_translation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "flashcards_note": {
      "type": "string"
    },
    "exercises": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/group"
      }
    },
    "test": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/item"
      }
    },
    "story": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sections",
        "vocabulary_notes",
        "questions"
      ],
      "properties": {
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "sentences"
            ],
            "properties": {
              "heading": {
                "type": "string"
              },
              "sentences": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "target",
                    "translation"
                  ],
                  "properties": {
                    "target": {
                      "type": "string",
                      "minLength": 1
                    },
                    "translation": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          }
        },
        "vocabulary_notes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "target",
              "note"
            ],
            "properties": {
              "target": {
                "type": "string",
                "minLength": 1
              },
              "note": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/answer_item"
          }
        },
        "practice": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/answer_item"
          }
        }
      }
    }
  },
  "$defs": {
    "answer_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question",
        "answer"
      ],
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1
        },
        "answer": {
          "type": [
            "string",
            "number"
          ]
        },
        "explanation": {
          "type": "string"
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "question",
        "answer",
        "explanation"
      ],
      "properties": {
        "type": {
          "enum": [
            "multiple_choice",
            "fill_blank",
            "translation",
            "matching",
            "short_answer",
            "ordering",
            "transformation",
            "correction",
            "classification",
            "production",
            "contrast",
            "identification",
            "dictation"
          ]
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "answer": {
          "type": [
            "string",
            "number"
          ]
        },
        "explanation": {
          "type": "string",
          "minLength": 1
        },
        "distractors": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "points": {
          "type": "number",
          "minimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "multiple_choice"
              }
            }
          },
          "then": {
            "required": [
              "distractors"
            ]
          }
        }
      ]
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "instruction",
        "items"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "instruction": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/item"
          }
        }
      }
    }
  }
}
